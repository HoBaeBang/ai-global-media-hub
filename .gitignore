# ==========================================
# 1. 모든 파일 무시 (기본 설정)
# ==========================================
/*

# ==========================================
# 2. 관리 대상 예외 처리 (올라가야 하는 것들)
# ==========================================

# 자동화 소스코드 및 설정 폴더
!/automation/
!/.github/    # GitHub Actions 워크플로우

# 설정 파일 및 정보 파일
!/.gitignore
!/README.md
!/PRD.md

# ==========================================
# 3. 예외 폴더 안에서도 제외할 항목 (보안 및 캐시)
# ==========================================

# 파이썬 캐시
**/__pycache__/
**/*.py[cod]

# 가상 환경
**/venv/
**/.venv/

# 보안 필수 (절대 제외)
**/.env
**/credentials/ 
**/*.json
!**/package.json    # JSON 중 필요한 파일은 예외
!**/src/*.json      # 소스 내 필요한 설정 JSON이 있다면 예외

# OS 및 에디터
.DS_Store
.vscode/
.idea/