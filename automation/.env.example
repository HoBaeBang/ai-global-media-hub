# Environment variables for Blogger Automation

# 1. Supabase Settings
SUPABASE_URL=your_supabase_project_url
SUPABASE_KEY=your_supabase_api_key

# 2. Google Gemini API Key
GEMINI_API_KEY=your_gemini_api_key

# 3. Google Blogger API OAuth / Tokens
# (To be filled after setting up GCP OAuth credentials)
BLOGGER_CLIENT_ID=your_client_id
BLOGGER_CLIENT_SECRET=your_client_secret
BLOGGER_REFRESH_TOKEN=your_refresh_token
